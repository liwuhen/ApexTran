# ApexTran environment example
# Copy to `.env` and fill in the values you need. Everything is optional unless noted.

# ---------------------------------------------------------------------------
# Agent runtime
# ---------------------------------------------------------------------------
# Model is given as `provider:model_id`. Code default: openrouter:qwen/qwen3-coder-next
# ApexTran_MODEL=openrouter:qwen/qwen3-coder-next
# ApexTran_MAX_STEPS=50
# ApexTran_MAX_TOKENS=1024
# ApexTran_MODEL_TIMEOUT_SECONDS=300
# ApexTran_HOME=~/.ApexTran

# ---------------------------------------------------------------------------
# Provider credentials
# ---------------------------------------------------------------------------
# Settings read ApexTran_API_KEY and ApexTran_API_BASE directly. Provider-specific
# keys such as OPENROUTER_API_KEY may still be picked up by the underlying SDK.
# ApexTran_API_KEY=sk-...
# ApexTran_API_BASE=https://openrouter.ai/api/v1

# Upstream request shape:
#   completion  - completion-style requests (default)
#   responses   - OpenAI Responses API
#   messages    - chat-completions-style messages API
# ApexTran_API_FORMAT=completion

# Optional JSON forwarded to the model client (set to `null` to disable).
# ApexTran_CLIENT_ARGS={"extra_headers":{"X-Title":"ApexTran"}}

# ---------------------------------------------------------------------------
# Channel manager
# ---------------------------------------------------------------------------
# Comma-separated channel names, or `all` (which excludes the builtin `cli`).
# ApexTran_ENABLED_CHANNELS=all
# ApexTran_DEBOUNCE_SECONDS=1.0
# ApexTran_MAX_WAIT_SECONDS=10.0
# ApexTran_ACTIVE_TIME_WINDOW=60.0

# ---------------------------------------------------------------------------
# Web gateway / frontend API bridge (optional)
# ---------------------------------------------------------------------------
# `uv run ApexTran web` serves the browser-facing WebChannel used by the Next.js
# frontend. Bind to 127.0.0.1 when Nginx runs on the same host. Bind to 0.0.0.0
# inside Docker and publish the port only on host loopback.
# ApexTran_WEB_HOST=127.0.0.1
# ApexTran_WEB_PORT=8000

# Docker image startup mode. The default remains `gateway`; use `web` for the
# frontend backend behind Nginx.
# ApexTran_START_MODE=web

# ---------------------------------------------------------------------------
# Telegram channel (optional)
# ---------------------------------------------------------------------------
# ApexTran_TELEGRAM_TOKEN=123456:telegram-bot-token
# ApexTran_TELEGRAM_ALLOW_USERS=123456789,my_username
# ApexTran_TELEGRAM_ALLOW_CHATS=123456789,-1001234567890
# ApexTran_TELEGRAM_PROXY=http://127.0.0.1:1080

# ---------------------------------------------------------------------------
# Feishu channel (optional)
# ---------------------------------------------------------------------------
# ApexTran_FEISHU_APP_ID=cli_...
# ApexTran_FEISHU_APP_SECRET=...
# ApexTran_FEISHU_ALLOW_USERS=
# ApexTran_FEISHU_ALLOW_CHATS=

# ---------------------------------------------------------------------------
# Embedding model (optional)
# ---------------------------------------------------------------------------
# ApexTran_Embedding_model_name=
# ApexTran_Embedding_api_key=

# ---------------------------------------------------------------------------
# Postgres / pgvector store (optional)
# ---------------------------------------------------------------------------
# ApexTran_SQL_host=localhost
# ApexTran_SQL_port=5432
# ApexTran_SQL_user=ApexTran
# ApexTran_SQL_password=
# ApexTran_SQL_dbname=ApexTran

# ---------------------------------------------------------------------------
# Logging (loguru). Console level defaults from ApexTran_VERBOSE; a rotating file
# sink at ApexTran_LOG_DIR/ApexTran.log is always added. See docs/logging.md.
# ---------------------------------------------------------------------------
# ApexTran_LOG_LEVEL=INFO            # console level (DEBUG/INFO/WARNING/ERROR)
# ApexTran_LOG_FILE_LEVEL=DEBUG      # file level (can be finer than console)
# ApexTran_LOG_DIR=~/.ApexTran/logs    # log directory
# ApexTran_LOG_ROTATION=20 MB        # rotate at size (or e.g. "1 day")
# ApexTran_LOG_RETENTION=14 days     # keep rotated logs this long
# ApexTran_LOG_JSON=0                # 1 = JSON lines in the file sink (for Loki/ELK)
# ApexTran_LOG_DIAGNOSE=0            # 1 = expand variable values in tracebacks (dev only)
